{
  "name": "loadouts",
  "version": "0.2.3",
  "description": "Composable configuration bundles for AI coding agents",
  "type": "module",
  "bin": {
    "loadouts": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "bundled"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "loadouts": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "configuration",
    "claude",
    "cursor",
    "opencode",
    "codex"
  ],
  "author": "Evatt",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/evatths/loadouts.git"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/update-notifier": "^6.0.8",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "update-notifier": "^7.3.1",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  }
}
